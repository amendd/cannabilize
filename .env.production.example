# ============================================
# VARIÁVEIS DE AMBIENTE - PRODUÇÃO
# ============================================
# 
# ⚠️ IMPORTANTE:
# - NUNCA commitar este arquivo com valores reais
# - Copie este arquivo para .env.production
# - Preencha com valores reais de produção
# - Adicione .env.production ao .gitignore
#
# ============================================

# ============================================
# BANCO DE DADOS
# ============================================
# PostgreSQL em produção (NÃO usar SQLite!)
# Exemplo Supabase:
# DATABASE_URL="postgresql://postgres.xxxxx:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require"
# Exemplo Neon:
# DATABASE_URL="postgresql://usuario:senha@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://usuario:senha@host:5432/nome_banco?schema=public&sslmode=require"

# ============================================
# AUTENTICAÇÃO (NextAuth)
# ============================================
# URL do site em produção (com https://)
NEXTAUTH_URL="https://seudominio.com.br"
# Secret aleatório (gerar com: openssl rand -base64 32)
NEXTAUTH_SECRET="GERE-UM-SECRET-ALEATORIO-AQUI-MINIMO-32-CARACTERES"

# ============================================
# AMBIENTE
# ============================================
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://seudominio.com.br"

# ============================================
# STRIPE (Pagamentos)
# ============================================
# Chaves de PRODUÇÃO (não usar chaves de teste!)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ============================================
# EMAIL (SMTP)
# ============================================
# Configuração do servidor de email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seu-email@seudominio.com.br"
SMTP_PASSWORD="senha-do-app"
SMTP_FROM="noreply@seudominio.com.br"

# ============================================
# WHATSAPP (Opcional)
# ============================================
WHATSAPP_API_KEY=""
WHATSAPP_PHONE_NUMBER=""

# ============================================
# GOOGLE MEET (Opcional)
# ============================================
GOOGLE_MEET_API_KEY=""

# ============================================
# AWS S3 (Uploads de Arquivos)
# ============================================
# Se usar uploads de arquivos, configure S3
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="clickcannabis-prod"
AWS_REGION="us-east-1"

# ============================================
# MONITORAMENTO (Opcional)
# ============================================
# Sentry para tracking de erros
SENTRY_DSN=""
# Google Analytics
NEXT_PUBLIC_GA_ID=""

# ============================================
# reCAPTCHA (Opcional, recomendado para formulários)
# ============================================
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""
RECAPTCHA_THRESHOLD=0.5

# ============================================
# OUTRAS CONFIGURAÇÕES
# ============================================
# Adicione outras variáveis conforme necessário
