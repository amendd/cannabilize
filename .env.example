# reCAPTCHA v3
# Obtenha suas chaves em: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=seu_site_key_aqui
RECAPTCHA_SECRET_KEY=seu_secret_key_aqui

# Threshold reCAPTCHA (0.0 a 1.0, padrão: 0.5)
# Quanto menor, mais restritivo. Recomendado: 0.5
RECAPTCHA_THRESHOLD=0.5

# Rate Limiting
RATE_LIMIT_ENABLED=true

# Redis (opcional, para rate limiting em produção)
# RATE_LIMIT_REDIS_URL=redis://localhost:6379

# Segurança
CSRF_ENABLED=true
HONEYPOT_ENABLED=true
SECURITY_LOGGING=true

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=seu_secret_aqui

# Database
DATABASE_URL="file:./dev.db"

# Outras variáveis do projeto...
