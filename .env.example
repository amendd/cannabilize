# reCAPTCHA v3
# Obtenha suas chaves em: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=seu_site_key_aqui
RECAPTCHA_SECRET_KEY=seu_secret_key_aqui

# Threshold reCAPTCHA (0.0 a 1.0, padrão: 0.5)
# Quanto menor, mais restritivo. Recomendado: 0.5
RECAPTCHA_THRESHOLD=0.5

# Rate Limiting
RATE_LIMIT_ENABLED=true

# Redis (opcional, para rate limiting em produção)
# RATE_LIMIT_REDIS_URL=redis://localhost:6379

# Segurança
CSRF_ENABLED=true
HONEYPOT_ENABLED=true
SECURITY_LOGGING=true

# NextAuth
# Use localhost para uso só na sua máquina. Para acesso pela rede (ex.: colegas em 10.0.0.115:3000), use:
# NEXTAUTH_URL=http://10.0.0.115:3000
# Para expor com ngrok: crie .env.local com NEXTAUTH_URL=https://SEU-SUBDOMINIO.ngrok-free.dev
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=seu_secret_aqui

# Cron (Vercel Cron envia este valor no header Authorization ao chamar as rotas de lembrete)
# Defina na Vercel: Project → Settings → Environment Variables → CRON_SECRET
# CRON_SECRET=seu_cron_secret_aqui

# URL pública da aplicação — usado em links de pagamento, concluir cadastro, WhatsApp e e-mail.
# Recomendado: defina SITE_PUBLIC_URL com o domínio que deve aparecer nos links (ex.: https://cannabilize.com.br).
# Assim os links no WhatsApp/e-mail usam sempre esse domínio, mesmo com NEXTAUTH_URL em ngrok ou app. em dev.
# SITE_PUBLIC_URL=https://cannabilize.com.br
# APP_URL=https://cannabilize.com.br
# NEXT_PUBLIC_APP_URL=https://cannabilize.com.br
# NEXTAUTH_URL=https://cannabilize.com.br
# Para ngrok/local: NEXTAUTH_URL e APP_URL podem ser ngrok; SITE_PUBLIC_URL mantém cannabilize.com.br nos links.
# TWILIO_WEBHOOK_BASE_URL=https://cannabilize.com.br  (URL do webhook no painel Twilio)
# Token para verificação do webhook Meta. Use o MESMO valor em Meta for Developers → Webhook → Verificar token e no Admin → WhatsApp → Meta.
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=cannabilize-wa-verify-x7k9m2p4
# NEXT_PUBLIC_BASE_URL=https://SEU-SUBDOMINIO.ngrok-free.dev      (links em e-mails, ex.: convite reagendamento)
#
# Deploy na Umbler (hospedagem): use a URL do app (ex.: https://seu-app.umbler.io) em NEXTAUTH_URL, APP_URL e NEXT_PUBLIC_APP_URL.
# A Umbler define PORT automaticamente; o script "start" do package.json já usa PORT.
# Guia completo: GUIA_INTEGRACAO_UMBLER.md
#
# Umbler Talk (uTalk) – integração descontinuada. WhatsApp via Z-API ou Twilio: use /api/whatsapp/zapi-webhook ou /api/whatsapp/webhook.

# Database
DATABASE_URL="file:./dev.db"

# Google Analytics 4 (opcional)
# ID da Métrica do GA4 (formato G-XXXXXXXXXX). Se definido, o analytics é ativado mesmo sem config no admin.
# Obtenha em: Admin GA4 → Fluxos de dados → Seu fluxo da web → ID de medição
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Email - SMTP (Gmail Cannabilize ou outro)
# Usado quando não há configuração de email no painel Admin. Porta 587 = STARTTLS (não use SMTP_SECURE=true).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=senha-de-app-16-caracteres
# Remetente (nome e email). Ex: "CannabiLizi <cannabilizeagora@gmail.com>"
SMTP_FROM="CannabiLizi <seu-email@gmail.com>"
SMTP_REPLY_TO=seu-email@gmail.com
# Só use true para porta 465 (SSL). Para Gmail 587 deixe false ou não defina.
# SMTP_SECURE=false

# Laudo por IA (gravação + transcrição + laudo médico)
# Geração de rascunho de laudo a partir da transcrição da consulta Zoom.
# Obtenha em https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# Modelo opcional (padrão: gpt-4o-mini). Ex.: gpt-4o para maior qualidade.
# OPENAI_LAUDO_MODEL=gpt-4o-mini

# IA no WhatsApp (dúvidas que não caíram no FAQ). Usa OPENAI_API_KEY se OPENAI_WHATSAPP_API_KEY não estiver definida.
# OPENAI_WHATSAPP_API_KEY=sk-...
# OPENAI_WHATSAPP_MODEL=gpt-4o-mini

# Outras variáveis do projeto...
