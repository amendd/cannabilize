{
    "name": "clickcannabis-replica",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "dev:tunnel": "concurrently --names \"next,ngrok\" -c \"cyan,magenta\" \"npm run dev\" \"ngrok http 3000\"",
        "build": "prisma generate && next build",
        "build:analyze": "next build",
        "start": "next start -p ${PORT:-3000}",
        "lint": "next lint",
        "postinstall": "prisma generate",
        "db:generate": "prisma generate",
        "db:push": "prisma db push",
        "db:migrate": "prisma migrate dev",
        "db:studio": "prisma studio",
        "db:seed": "tsx prisma/seed.ts"
    },
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    },
    "dependencies": {
        "@hookform/resolvers": "^3.3.4",
        "@prisma/client": "^5.19.0",
        "@stripe/stripe-js": "^4.0.0",
        "@types/qrcode": "^1.5.6",
        "axios": "^1.7.0",
        "axios-oauth-client": "^1.0.0",
        "bcryptjs": "^2.4.3",
        "clsx": "^2.1.0",
        "date-fns": "^3.6.0",
        "dotenv": "^17.2.3",
        "framer-motion": "^11.3.0",
        "googleapis": "^128.0.0",
        "html2canvas": "^1.4.1",
        "jspdf": "^2.5.1",
        "lucide-react": "^0.427.0",
        "next": "^14.2.0",
        "next-auth": "^4.24.7",
        "nodemailer": "^7.0.13",
        "pdf-lib": "^1.17.1",
        "qrcode": "^1.5.4",
        "react": "^18.3.0",
        "react-dom": "^18.3.0",
        "react-hook-form": "^7.52.0",
        "react-hot-toast": "^2.4.1",
        "resend": "^6.9.1",
        "stripe": "^17.0.0",
        "swr": "^2.4.0",
        "tailwind-merge": "^2.4.0",
        "twilio": "^5.3.5",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@next/bundle-analyzer": "^16.1.6",
        "@types/bcryptjs": "^2.4.6",
        "@types/node": "^20.14.0",
        "@types/nodemailer": "^7.0.9",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "autoprefixer": "^10.4.19",
        "concurrently": "^9.2.1",
        "eslint": "^8.57.0",
        "eslint-config-next": "^14.2.0",
        "postcss": "^8.4.38",
        "prisma": "^5.19.0",
        "tailwindcss": "^3.4.0",
        "tsx": "^4.7.0",
        "typescript": "^5.5.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
